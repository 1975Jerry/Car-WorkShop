@inherits LayoutComponentBase
@using MediatR
@using Workshop.Application.Common.Abstractions
@using Workshop.Application.Features.Branches
@using Workshop.Domain.Entities.Identity
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject IBranchScopeState ScopeState
@inject NavigationManager NavigationManager

<MudThemeProvider Theme="@Workshop.Web.Theme.PaintBullTheme.Light" IsDarkMode="@_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" OnClick="ToggleDrawer" Edge="Edge.Start" />
        <MudText Typo="Typo.h6" Class="ms-3">Paint Bull</MudText>
        <MudSpacer />
        @if (_canSwitchBranch && _branches.Count > 0)
        {
            <MudSelect T="Guid?" Value="@_selectedBranchId" ValueChanged="OnBranchChanged"
                       Dense Margin="Margin.None" Variant="Variant.Outlined"
                       Style="max-width:220px; background:white; border-radius:4px;">
                <MudSelectItem T="Guid?" Value="@((Guid?)null)">@L["AllBranches"]</MudSelectItem>
                @foreach (var b in _branches)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)b.Id)">@b.Name</MudSelectItem>
                }
            </MudSelect>
        }
        <MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit">
            <MudMenuItem OnClick="@(() => SetLang("el"))">Ελληνικά</MudMenuItem>
            <MudMenuItem OnClick="@(() => SetLang("en"))">English</MudMenuItem>
        </MudMenu>
        <MudIconButton Icon="@(_isDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" Color="Color.Inherit" OnClick="@(() => _isDark = !_isDark)" />
        <AuthorizeView>
            <Authorized>
                <Workshop.Web.Components.Shared.NotificationBell />
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit">
                    <MudText Class="px-4 py-2" Typo="Typo.body2">@context.User.Identity?.Name</MudText>
                    <MudDivider />
                    <MudMenuItem Href="/Account/Logout" ForceLoad>@L["SignOut"]</MudMenuItem>
                </MudMenu>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="DrawerVariant.Mini" OpenMiniOnHover Anchor="Anchor.Left">
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Dashboard">@L["Dashboard"]</MudNavLink>
            <MudNavLink Href="/cases/insurance" Icon="@Icons.Material.Filled.Folder">@L["InsuranceCases"]</MudNavLink>
            <MudNavLink Href="/cases/retail" Icon="@Icons.Material.Filled.Store">@L["RetailCases"]</MudNavLink>
            <MudNavLink Href="/customers" Icon="@Icons.Material.Filled.People">@L["Customers"]</MudNavLink>
            <MudNavLink Href="/vehicles" Icon="@Icons.Material.Filled.DirectionsCar">@L["Vehicles"]</MudNavLink>
            <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.Assessment">@L["Reports"]</MudNavLink>
            <MudNavLink Href="/admin" Icon="@Icons.Material.Filled.Settings">@L["Admin"]</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDark;
    private bool _canSwitchBranch;
    private Guid? _selectedBranchId;
    private IReadOnlyList<BranchListItemDto> _branches = Array.Empty<BranchListItemDto>();

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override async Task OnInitializedAsync()
    {
        _canSwitchBranch = CurrentUser.IsInRole(RoleNames.Admin);
        if (!_canSwitchBranch) return;

        var page = await Mediator.Send(new ListBranchesQuery(IsActive: true, PageSize: 200));
        _branches = page.Items.OrderBy(b => b.Name).ToList();
        _selectedBranchId = ScopeState.OverrideBranchId;
    }

    private void OnBranchChanged(Guid? branchId)
    {
        if (_selectedBranchId == branchId) return;
        _selectedBranchId = branchId;
        ScopeState.SetOverride(branchId);
        // Force-reload the current page so any query that ran during OnInitializedAsync
        // re-evaluates under the new scope.
        var current = new Uri(NavigationManager.Uri).GetComponents(UriComponents.PathAndQuery, UriFormat.Unescaped);
        NavigationManager.NavigateTo(current, forceLoad: true);
    }

    private void SetLang(string lang)
    {
        // /api/culture writes the RequestLocalization cookie server-side then
        // bounces back. Full reload is required because the Blazor circuit
        // caches CultureInfo for IStringLocalizer.
        var uri = new Uri(NavigationManager.Uri).GetComponents(UriComponents.PathAndQuery, UriFormat.Unescaped);
        NavigationManager.NavigateTo($"/api/culture?culture={lang}&redirectUri={Uri.EscapeDataString(uri)}", forceLoad: true);
    }
}
