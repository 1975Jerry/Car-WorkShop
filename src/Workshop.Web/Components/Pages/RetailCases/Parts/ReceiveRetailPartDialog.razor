@using MediatR
@using MudBlazor
@using Workshop.Application.Common.Lookups
@inject IMediator Mediator
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">@PartName</MudText>
        <MudGrid>
            <MudItem xs="12">
                <MudSelect T="Guid?" @bind-Value="_warehouseId" Label="@L["Warehouse"]" Required
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var w in _warehouses)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)w.Id)">@w.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_storage" Label="@L["StorageLocation"]"
                              Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="100" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Ok" Disabled="@(_warehouseId is null)">
            @L["Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = null!;
    [Parameter] public string PartName { get; set; } = string.Empty;

    private Guid? _warehouseId;
    private string? _storage;
    private IReadOnlyList<LookupItem> _warehouses = Array.Empty<LookupItem>();

    protected override async Task OnInitializedAsync()
    {
        _warehouses = await Mediator.Send(new GetWarehouseLookupQuery());
    }

    private void Ok() => Dialog.Close(DialogResult.Ok(new ReceivePartResult(_warehouseId!.Value, _storage)));
    private void Cancel() => Dialog.Cancel();
}
