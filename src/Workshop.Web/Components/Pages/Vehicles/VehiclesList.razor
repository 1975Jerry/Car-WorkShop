@page "/vehicles"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Workshop.Application.Common.Messaging
@using MudBlazor
@using Workshop.Application.Common.Lookups
@using Workshop.Application.Features.Vehicles
@inject IMediator Mediator
@inject IDialogService Dialogs
@inject ISnackbar Snackbar
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<PageTitle>Paint Bull — @L["Vehicles"]</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["Vehicles"]</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
    <MudGrid>
        <MudItem xs="12" md="5">
            <MudTextField @bind-Value="_search" Label="@L["Search"]" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          DebounceInterval="300" OnDebounceIntervalElapsed="Reload" Clearable />
        </MudItem>
        <MudItem xs="6" md="5">
            <MudAutocomplete T="LookupItem" Label="@L["Customer"]" SearchFunc="SearchCustomers"
                             Value="_customerFilter" ValueChanged="OnCustomerFilterChanged"
                             ToStringFunc="@(x => x?.Label ?? "")"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Clearable
                             ShowProgressIndicator />
        </MudItem>
        <MudItem xs="6" md="2" Class="d-flex justify-end">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreate">@L["New"]</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable ServerData="LoadData" T="VehicleListItemDto" Dense Hover Striped
          @ref="_table" Loading="@_loading">
    <HeaderContent>
        <MudTh>@L["PlateNumber"]</MudTh>
        <MudTh>@L["Brand"]</MudTh>
        <MudTh>@L["Model"]</MudTh>
        <MudTh>@L["Year"]</MudTh>
        <MudTh>@L["Customer"]</MudTh>
        <MudTh>@L["InsuranceCompany"]</MudTh>
        <MudTh Style="text-align:center">@L["Active"]</MudTh>
        <MudTh Style="width:120px"></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><strong>@context.PlateNumber</strong></MudTd>
        <MudTd>@context.Brand</MudTd>
        <MudTd>@context.Model</MudTd>
        <MudTd>@context.Year</MudTd>
        <MudTd>@context.CustomerDisplayName</MudTd>
        <MudTd>@context.InsuranceCompanyName</MudTd>
        <MudTd Style="text-align:center">
            @if (context.IsActive)
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Block" Color="Color.Default" Size="Size.Small" />
            }
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           OnClick="@(() => OpenEdit(context.Id))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                           OnClick="@(() => OpenDelete(context))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="@(new[] { 25, 50, 100 })" />
    </PagerContent>
</MudTable>

@code {
    private MudTable<VehicleListItemDto>? _table;
    private string? _search;
    private LookupItem? _customerFilter;
    private bool _loading;

    private async Task<TableData<VehicleListItemDto>> LoadData(TableState state, CancellationToken ct)
    {
        _loading = true;
        try
        {
            var result = await Mediator.Send(new ListVehiclesQuery(
                Search: _search,
                CustomerId: _customerFilter?.Id,
                Page: state.Page + 1,
                PageSize: state.PageSize), ct);
            return new TableData<VehicleListItemDto> { Items = result.Items, TotalItems = result.TotalCount };
        }
        finally { _loading = false; }
    }

    private async Task<IEnumerable<LookupItem>> SearchCustomers(string? value, CancellationToken ct) =>
        await Mediator.Send(new GetCustomerLookupQuery(value), ct);

    private async Task OnCustomerFilterChanged(LookupItem? value)
    {
        _customerFilter = value;
        await Reload();
    }

    private Task Reload() => _table?.ReloadServerData() ?? Task.CompletedTask;

    private async Task OpenCreate()
    {
        var p = new DialogParameters { ["Id"] = (Guid?)null };
        var dialog = await Dialogs.ShowAsync<VehicleEditDialog>(L["NewVehicle"], p,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        if ((await dialog.Result)?.Canceled == false) await Reload();
    }

    private async Task OpenEdit(Guid id)
    {
        var p = new DialogParameters { ["Id"] = (Guid?)id };
        var dialog = await Dialogs.ShowAsync<VehicleEditDialog>(L["EditVehicle"], p,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        if ((await dialog.Result)?.Canceled == false) await Reload();
    }

    private async Task OpenDelete(VehicleListItemDto v)
    {
        var ok = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = L["ConfirmDelete"],
            Message = $"{L["ConfirmDeleteVehicle"]}\n\n{v.PlateNumber} — {v.Brand} {v.Model}",
            YesText = L["Delete"],
            CancelText = L["Cancel"]
        });
        if (ok == true)
        {
            try
            {
                await Mediator.Send(new DeleteVehicleCommand(v.Id));
                Snackbar.Add(L["DeletedSuccessfully"], Severity.Success);
                await Reload();
            }
            catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        }
    }
}
