@page "/insurer"
@page "/insurer/cases"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "InsurerPortal")]
@layout Workshop.Web.Components.Layout.InsurerLayout
@using MediatR
@using MudBlazor
@using Workshop.Application.Common.Abstractions
@using Workshop.Application.Features.InsurerPortal
@using Workshop.Domain.Enums
@inject IMediator Mediator
@inject NavigationManager Nav
@inject ICurrentUserService CurrentUser
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<PageTitle>Paint Bull — @L["AssignedCases"]</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["AssignedCases"]</MudText>

<MudPaper Class="pa-3 mb-3" Outlined Elevation="0">
    <MudSelect T="ApprovalStatus?" @bind-Value="_filter" @bind-Value:after="Reload"
               Label="@L["Status"]" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
        <MudSelectItem T="ApprovalStatus?" Value="null">@L["All"]</MudSelectItem>
        <MudSelectItem T="ApprovalStatus?" Value="@((ApprovalStatus?)ApprovalStatus.Pending)">@L["Pending"]</MudSelectItem>
        <MudSelectItem T="ApprovalStatus?" Value="@((ApprovalStatus?)ApprovalStatus.Approved)">@L["Approve"]</MudSelectItem>
        <MudSelectItem T="ApprovalStatus?" Value="@((ApprovalStatus?)ApprovalStatus.Rejected)">@L["Reject"]</MudSelectItem>
    </MudSelect>
</MudPaper>

<MudTable ServerData="LoadData" T="InsurerCaseListItemDto" Dense Hover Striped @ref="_table"
          OnRowClick="OnRowClick" RowClass="cursor-pointer">
    <HeaderContent>
        <MudTh>@L["CaseNumber"]</MudTh>
        <MudTh>@L["ClaimNumber"]</MudTh>
        <MudTh>@L["Customer"]</MudTh>
        <MudTh>@L["Vehicle"]</MudTh>
        <MudTh>@L["AccidentDate"]</MudTh>
        <MudTh>@L["ApprovalDecision"]</MudTh>
        <MudTh Class="text-right">@L["ApprovedAmount"]</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><strong>@context.CaseNumber</strong></MudTd>
        <MudTd>@(context.ClaimNumber ?? "—")</MudTd>
        <MudTd>@context.CustomerDisplayName</MudTd>
        <MudTd>@context.VehiclePlate — @context.VehicleBrandModel</MudTd>
        <MudTd>@(context.AccidentDate?.ToString("yyyy-MM-dd") ?? "—")</MudTd>
        <MudTd>
            @if (context.ApprovalStatus is null)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default">@L["Pending"]</MudChip>
            }
            else
            {
                <MudChip T="string" Size="Size.Small" Color="@DecisionColor(context.ApprovalStatus.Value)">
                    @L[$"AS_{context.ApprovalStatus}"]
                </MudChip>
            }
        </MudTd>
        <MudTd Class="text-right">@(context.ApprovedAmount?.ToString("N2") ?? "—")</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="@(new[] { 25, 50, 100 })" />
    </PagerContent>
</MudTable>

<style>.cursor-pointer td { cursor: pointer; } .text-right { text-align: right; }</style>

@code {
    private MudTable<InsurerCaseListItemDto>? _table;
    private ApprovalStatus? _filter;

    private async Task<TableData<InsurerCaseListItemDto>> LoadData(TableState state, CancellationToken ct)
    {
        var companyId = CurrentUser.InsuranceCompanyId;
        if (companyId is null)
            return new TableData<InsurerCaseListItemDto> { Items = [], TotalItems = 0 };
        var r = await Mediator.Send(new ListInsurerCasesQuery(
            companyId.Value, _filter, state.Page + 1, state.PageSize), ct);
        return new TableData<InsurerCaseListItemDto> { Items = r.Items, TotalItems = r.TotalCount };
    }

    private Task Reload() => _table?.ReloadServerData() ?? Task.CompletedTask;

    private void OnRowClick(TableRowClickEventArgs<InsurerCaseListItemDto> args) =>
        Nav.NavigateTo($"/insurer/cases/{args.Item!.Id}");

    private static Color DecisionColor(ApprovalStatus s) => s switch
    {
        ApprovalStatus.Approved => Color.Success,
        ApprovalStatus.Rejected => Color.Error,
        _ => Color.Default
    };
}
