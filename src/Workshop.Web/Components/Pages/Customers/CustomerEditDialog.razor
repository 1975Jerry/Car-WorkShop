@using MediatR
@using MudBlazor
@using Workshop.Application.Features.Customers
@using Workshop.Domain.Enums
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_data">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudSelect T="CustomerType" @bind-Value="_data.CustomerType" Label="@L["CustomerType"]"
                               Variant="Variant.Outlined" Required Margin="Margin.Dense">
                        <MudSelectItem Value="@CustomerType.Individual">@L["Individual"]</MudSelectItem>
                        <MudSelectItem Value="@CustomerType.Company">@L["Company"]</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSwitch T="bool" @bind-Value="_data.IsActive" Color="Color.Success" Label="@L["Active"]" />
                </MudItem>

                @if (_data.CustomerType == CustomerType.Individual)
                {
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_data.FirstName" Label="@L["FirstName"]"
                                      Required Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_data.LastName" Label="@L["LastName"]"
                                      Required Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_data.IdNumber" Label="@L["IdNumber"]"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_data.VatNumber" Label="@L["VatNumber"]"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_data.CompanyName" Label="@L["CompanyName"]"
                                      Required Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_data.VatNumber" Label="@L["VatNumber"]"
                                      Required Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_data.TaxOffice" Label="@L["TaxOffice"]"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                }

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_data.MobilePhone" Label="@L["MobilePhone"]"
                                  Required Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_data.SecondaryPhone" Label="@L["SecondaryPhone"]"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_data.Email" Label="@L["Email"]" InputType="InputType.Email"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_data.AddressLine" Label="@L["Address"]"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="_data.City" Label="@L["City"]"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_data.PostalCode" Label="@L["PostalCode"]"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Value="_data.GdprConsent" Label="@L["GdprConsent"]" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_data.Notes" Label="@L["Notes"]" Lines="3"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@_saving">
            @L["Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter] public Guid? Id { get; set; }

    private MudForm? _form;
    private bool _saving;
    private FormModel _data = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var c = await Mediator.Send(new GetCustomerByIdQuery(Id.Value));
            if (c is not null)
            {
                _data = new FormModel
                {
                    CustomerType = c.CustomerType,
                    FirstName = c.FirstName,
                    LastName = c.LastName,
                    CompanyName = c.CompanyName,
                    VatNumber = c.VatNumber,
                    TaxOffice = c.TaxOffice,
                    IdNumber = c.IdNumber,
                    MobilePhone = c.MobilePhone,
                    SecondaryPhone = c.SecondaryPhone,
                    Email = c.Email,
                    AddressLine = c.AddressLine,
                    City = c.City,
                    PostalCode = c.PostalCode,
                    GdprConsent = c.GdprConsent,
                    Notes = c.Notes,
                    IsActive = c.IsActive
                };
            }
        }
    }

    private async Task Submit()
    {
        _saving = true;
        try
        {
            var dto = new CustomerUpsertDto(
                _data.CustomerType, _data.FirstName, _data.LastName, _data.CompanyName,
                _data.VatNumber, _data.TaxOffice, _data.IdNumber, _data.MobilePhone,
                _data.SecondaryPhone, _data.Email, _data.AddressLine, _data.City, _data.PostalCode,
                _data.GdprConsent, _data.Notes, _data.IsActive);

            Guid resultId;
            if (Id.HasValue)
            {
                await Mediator.Send(new UpdateCustomerCommand(Id.Value, dto));
                resultId = Id.Value;
            }
            else
            {
                resultId = await Mediator.Send(new CreateCustomerCommand(dto));
            }

            Snackbar.Add(L["SavedSuccessfully"], Severity.Success);
            Dialog.Close(DialogResult.Ok(resultId));
        }
        catch (FluentValidation.ValidationException ex)
        {
            foreach (var e in ex.Errors)
                Snackbar.Add(e.ErrorMessage, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => Dialog.Cancel();

    private class FormModel
    {
        public CustomerType CustomerType { get; set; } = CustomerType.Individual;
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? CompanyName { get; set; }
        public string? VatNumber { get; set; }
        public string? TaxOffice { get; set; }
        public string? IdNumber { get; set; }
        public string MobilePhone { get; set; } = string.Empty;
        public string? SecondaryPhone { get; set; }
        public string? Email { get; set; }
        public string? AddressLine { get; set; }
        public string? City { get; set; }
        public string? PostalCode { get; set; }
        public bool GdprConsent { get; set; }
        public string? Notes { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
