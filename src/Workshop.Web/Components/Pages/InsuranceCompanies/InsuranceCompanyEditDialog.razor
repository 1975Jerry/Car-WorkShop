@using MediatR
@using MudBlazor
@using Workshop.Application.Features.InsuranceCompanies
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_data.Name" Label="@L["Name"]" Required
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_data.VatNumber" Label="@L["VatNumber"]"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6">
                <MudSwitch T="bool" @bind-Value="_data.IsActive" Color="Color.Success" Label="@L["Active"]" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_data.Phone" Label="@L["Phone"]"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_data.Email" Label="@L["Email"]" InputType="InputType.Email"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_data.AddressLine" Label="@L["Address"]"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_data.Notes" Label="@L["Notes"]" Lines="2"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => Dialog.Cancel())">@L["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@_saving">
            @L["Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter] public Guid? Id { get; set; }
    private bool _saving;
    private FormModel _data = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Id.HasValue) return;
        var c = await Mediator.Send(new GetInsuranceCompanyByIdQuery(Id.Value));
        if (c is null) return;
        _data = new FormModel { Name = c.Name, VatNumber = c.VatNumber, Phone = c.Phone, Email = c.Email,
            AddressLine = c.AddressLine, Notes = c.Notes, IsActive = c.IsActive };
    }

    private async Task Submit()
    {
        _saving = true;
        try
        {
            var dto = new InsuranceCompanyUpsertDto(_data.Name, _data.VatNumber, _data.Phone,
                _data.Email, _data.AddressLine, _data.Notes, _data.IsActive);
            if (Id.HasValue) await Mediator.Send(new UpdateInsuranceCompanyCommand(Id.Value, dto));
            else await Mediator.Send(new CreateInsuranceCompanyCommand(dto));
            Snackbar.Add(L["SavedSuccessfully"], Severity.Success);
            Dialog.Close(DialogResult.Ok(true));
        }
        catch (FluentValidation.ValidationException ex)
        { foreach (var e in ex.Errors) Snackbar.Add(e.ErrorMessage, Severity.Error); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _saving = false; }
    }

    private class FormModel
    {
        public string Name { get; set; } = "";
        public string? VatNumber { get; set; }
        public string? Phone { get; set; }
        public string? Email { get; set; }
        public string? AddressLine { get; set; }
        public string? Notes { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
