@page "/supplier"
@page "/supplier/orders"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "SupplierPortal")]
@layout Workshop.Web.Components.Layout.SupplierLayout
@using Workshop.Application.Common.Messaging
@using MudBlazor
@using Workshop.Application.Common.Abstractions
@using Workshop.Application.Features.SupplierPortal
@using Workshop.Domain.Enums
@inject IMediator Mediator
@inject IDialogService Dialogs
@inject ISnackbar Snackbar
@inject ICurrentUserService CurrentUser
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<PageTitle>Paint Bull — @L["MyOrders"]</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["MyOrders"]</MudText>

<MudPaper Class="pa-3 mb-3" Outlined Elevation="0">
    <MudSelect T="PartReceivedStatus?" @bind-Value="_filter" @bind-Value:after="Reload"
               Label="@L["Status"]" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
        <MudSelectItem T="PartReceivedStatus?" Value="null">@L["All"]</MudSelectItem>
        @foreach (var s in Enum.GetValues<PartReceivedStatus>())
        {
            <MudSelectItem T="PartReceivedStatus?" Value="@((PartReceivedStatus?)s)">@L[$"PRS_{s}"]</MudSelectItem>
        }
    </MudSelect>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate Color="Color.Primary" />
}
else if (_rows.Count == 0)
{
    <MudAlert Severity="Severity.Info">@L["NoOrdersYet"]</MudAlert>
}
else
{
    <MudSimpleTable Dense Hover Striped Bordered Style="overflow-x: auto;">
        <thead>
            <tr>
                <th>@L["CaseNumber"]</th>
                <th>@L["PartName"]</th>
                <th>@L["PartType"]</th>
                <th style="text-align:right;">@L["Quantity"]</th>
                <th style="text-align:right;">@L["UnitCost"]</th>
                <th style="text-align:right;">@L["Total"]</th>
                <th>@L["DestinationBranch"]</th>
                <th>@L["Status"]</th>
                <th style="width: 60px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in _rows)
            {
                <tr>
                    <td>
                        <strong>@r.CaseNumber</strong>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@KindLabel(r.Kind)</MudText>
                    </td>
                    <td>
                        @r.PartName
                        @if (!string.IsNullOrWhiteSpace(r.Notes))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@r.Notes</MudText>
                        }
                    </td>
                    <td>@L[$"PT_{r.PartType}"]</td>
                    <td style="text-align:right;">@r.Quantity.ToString("0.##")</td>
                    <td style="text-align:right;">@r.UnitCost.ToString("N2")</td>
                    <td style="text-align:right;"><strong>@r.Total.ToString("N2")</strong></td>
                    <td>@r.DestinationBranchName</td>
                    <td>
                        <MudChip T="string" Size="Size.Small" Color="@StatusColor(r.ReceivedStatus)">
                            @L[$"PRS_{r.ReceivedStatus}"]
                        </MudChip>
                    </td>
                    <td>
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense Size="Size.Small">
                            @foreach (var next in AllowedSupplierActions(r.ReceivedStatus))
                            {
                                <MudMenuItem OnClick="@(() => Act(r, next))">@ActionLabel(next)</MudMenuItem>
                            }
                        </MudMenu>
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private bool _loading = true;
    private PartReceivedStatus? _filter;
    private IReadOnlyList<SupplierOrderRow> _rows = Array.Empty<SupplierOrderRow>();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        _loading = true;
        var supplierId = CurrentUser.SupplierId;
        if (supplierId is null) { _rows = []; _loading = false; return; }
        _rows = await Mediator.Send(new ListSupplierOrdersQuery(supplierId.Value, _filter));
        _loading = false;
    }

    private async Task Act(SupplierOrderRow row, PartReceivedStatus target)
    {
        var supplierId = CurrentUser.SupplierId!.Value;
        string? notes = null;
        if (target == PartReceivedStatus.InTransit)
        {
            var parameters = new DialogParameters { ["Prompt"] = L["DispatchNotesLabel"] };
            var dlg = await Dialogs.ShowAsync<DispatchNoteDialog>(L["MarkInTransit"], parameters,
                new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
            var result = await dlg.Result;
            if (result is { Canceled: true }) return;
            notes = result?.Data as string;
        }
        try
        {
            await Mediator.Send(new SupplierDispatchCommand(supplierId, row.LineId, row.Kind, target, notes));
            Snackbar.Add(L["OrderActioned"], Severity.Success);
            await Reload();
        }
        catch (FluentValidation.ValidationException ex)
        { foreach (var e in ex.Errors) Snackbar.Add(e.ErrorMessage, Severity.Error); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private static IEnumerable<PartReceivedStatus> AllowedSupplierActions(PartReceivedStatus current) =>
        current switch
        {
            PartReceivedStatus.Pending => new[] { PartReceivedStatus.Ordered, PartReceivedStatus.Cancelled },
            PartReceivedStatus.Ordered => new[] { PartReceivedStatus.InTransit, PartReceivedStatus.Cancelled },
            PartReceivedStatus.InTransit => new[] { PartReceivedStatus.Cancelled },
            _ => Array.Empty<PartReceivedStatus>()
        };

    private string ActionLabel(PartReceivedStatus target) => target switch
    {
        PartReceivedStatus.Ordered => L["ConfirmOrder"],
        PartReceivedStatus.InTransit => L["MarkInTransit"],
        PartReceivedStatus.Cancelled => L["CancelOrder"],
        _ => L[$"PRS_{target}"]
    };

    private string KindLabel(SupplierLineKind kind) =>
        kind == SupplierLineKind.Insurance ? L["InsuranceCases"] : L["RetailCases"];

    private static Color StatusColor(PartReceivedStatus s) => s switch
    {
        PartReceivedStatus.Pending => Color.Default,
        PartReceivedStatus.Ordered => Color.Info,
        PartReceivedStatus.InTransit => Color.Warning,
        PartReceivedStatus.Received => Color.Success,
        PartReceivedStatus.Defective => Color.Error,
        PartReceivedStatus.Cancelled => Color.Dark,
        _ => Color.Default
    };
}
