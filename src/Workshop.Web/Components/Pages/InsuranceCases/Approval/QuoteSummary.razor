@using MudBlazor
@using Workshop.Application.Features.Quotes
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<MudPaper Class="pa-3 mb-3" Outlined Elevation="0">
    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
        <MudText Typo="Typo.subtitle1">@L["CurrentQuote"]</MudText>
        @if (Quote is not null)
        {
            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                @if (!string.IsNullOrWhiteSpace(Quote.PdfPath))
                {
                    <MudButton Href="@($"/{Quote.PdfPath}")" Target="_blank"
                               Variant="Variant.Outlined" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.PictureAsPdf">
                        @L["DownloadPdf"]
                    </MudButton>
                }
                <MudChip T="string" Size="Size.Small" Color="Color.Info" Text="@Quote.QuoteNumber" />
            </MudStack>
        }
    </MudStack>

    @if (Quote is null)
    {
        <MudAlert Severity="Severity.Info">@L["NoCurrentQuote"]</MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="6" md="3"><Field Label="@L["IssueDate"]" Value="@Quote.IssueDate.ToString("yyyy-MM-dd")" /></MudItem>
            <MudItem xs="6" md="3"><Field Label="@L["ResponsibleUser"]" Value="@Quote.ResponsibleUserName" /></MudItem>
            <MudItem xs="6" md="3"><Field Label="@L["LaborSubtotal"]" Value="@Quote.LaborSubtotal.ToString("0.00")" /></MudItem>
            <MudItem xs="6" md="3"><Field Label="@L["PartsSubtotal"]" Value="@Quote.PartsSubtotal.ToString("0.00")" /></MudItem>
            <MudItem xs="6" md="3"><Field Label="@L["Subtotal"]" Value="@Quote.Subtotal.ToString("0.00")" /></MudItem>
            <MudItem xs="6" md="3"><Field Label="@L["VatRate"]" Value="@(Quote.VatRate.ToString("0.##") + " %")" /></MudItem>
            <MudItem xs="6" md="3"><Field Label="@L["VatAmount"]" Value="@Quote.VatAmount.ToString("0.00")" /></MudItem>
            <MudItem xs="6" md="3"><Field Label="@L["Total"]" Value="@Quote.Total.ToString("0.00")" /></MudItem>
            @if (Quote.CustomerParticipation.HasValue)
            {
                <MudItem xs="6" md="3"><Field Label="@L["CustomerParticipation"]" Value="@Quote.CustomerParticipation.Value.ToString("0.00")" /></MudItem>
            }
        </MudGrid>
    }
</MudPaper>

@code {
    [Parameter] public QuoteDto? Quote { get; set; }
}
