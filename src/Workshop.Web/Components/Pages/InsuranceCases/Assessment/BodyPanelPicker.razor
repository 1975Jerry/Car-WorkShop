@using MudBlazor
@using Workshop.Application.Features.BodyPanels
@using Workshop.Domain.Enums
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<MudPaper Class="pa-3" Outlined Elevation="0">
    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
        <MudText Typo="Typo.subtitle1">@L["DamageSelector"]</MudText>
        <MudToggleGroup T="ViewMode" SelectionMode="SelectionMode.SingleSelection"
                        @bind-Value="_view" Size="Size.Small" Color="Color.Primary">
            <MudToggleItem Value="@ViewMode.Diagram">
                <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Class="mr-1" Size="Size.Small" />
                @L["DiagramView"]
            </MudToggleItem>
            <MudToggleItem Value="@ViewMode.List">
                <MudIcon Icon="@Icons.Material.Filled.ViewList" Class="mr-1" Size="Size.Small" />
                @L["ListView"]
            </MudToggleItem>
        </MudToggleGroup>
    </MudStack>

    <MudTextField @bind-Value="_search" Placeholder="@L["FilterPanels"]" Immediate
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Class="mb-2" />

    <MudStack Row Spacing="2" Class="mb-2">
        <MudChipSet T="BodyPanelCategory?" SelectedValue="_category" SelectedValueChanged="@(c => _category = c)"
                    SelectionMode="SelectionMode.SingleSelection">
            <MudChip T="BodyPanelCategory?" Value="@((BodyPanelCategory?)null)" Text="@L["AllCategories"]" />
            <MudChip T="BodyPanelCategory?" Value="@((BodyPanelCategory?)BodyPanelCategory.External)" Text="@L["External"]" />
            <MudChip T="BodyPanelCategory?" Value="@((BodyPanelCategory?)BodyPanelCategory.Internal)" Text="@L["Internal"]" />
            <MudChip T="BodyPanelCategory?" Value="@((BodyPanelCategory?)BodyPanelCategory.Safety)" Text="@L["Safety"]" />
        </MudChipSet>
    </MudStack>

    @if (Panels.Count == 0)
    {
        <MudProgressLinear Indeterminate />
    }
    else if (_view == ViewMode.Diagram)
    {
        <div class="bp-diagram-wrap">
            <img src="img/car-view.jpg" class="bp-diagram-img" alt="@L["DamageSelector"]" draggable="false" />
            @foreach (var panel in DiagramPanels)
            {
                var dimmed = !MatchesFilters(panel);
                var selected = SelectedPanelIds.Contains(panel.Id);
                var cls = "bp-hot" + (selected ? " bp-hot-sel" : "") + (dimmed ? " bp-hot-dim" : "");
                <button type="button" class="@cls"
                        style="@($"left:{Pct(panel.DiagramX!.Value)}%;top:{Pct(panel.DiagramY!.Value)}%;")"
                        title="@($"{panel.Code} · {panel.DescriptionGr}")"
                        aria-label="@($"{panel.Code} {panel.DescriptionGr}")"
                        aria-pressed="@selected"
                        disabled="@dimmed"
                        @onclick="@(() => OnPick(panel))">
                    <span class="bp-hot-code">@panel.Code</span>
                </button>
            }
        </div>

        @if (!DiagramPanels.Any(MatchesFilters))
        {
            <MudAlert Severity="Severity.Info" Dense Class="mt-2">@L["NoDiagramCoords"]</MudAlert>
        }
    }
    else
    {
        <div style="max-height: 480px; overflow-y: auto;">
            <MudList T="BodyPanelDto" Dense ReadOnly>
                @foreach (var panel in FilteredPanels)
                {
                    var isSel = SelectedPanelIds.Contains(panel.Id);
                    <MudListItem T="BodyPanelDto" Value="@panel"
                                 Icon="@(isSel ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.AddCircle)"
                                 IconColor="@(isSel ? Color.Success : Color.Primary)"
                                 OnClick="@(() => OnPick(panel))">
                        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Text="@panel.Code" />
                                <MudText Typo="Typo.body2">@panel.DescriptionGr</MudText>
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@SideLabel(panel.Side)</MudText>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        </div>
    }
</MudPaper>

<style>
    .bp-diagram-wrap { position: relative; max-width: 1120px; margin: 0 auto; line-height: 0; }
    .bp-diagram-img { width: 100%; height: auto; display: block; user-select: none; }
    .bp-hot {
        position: absolute; transform: translate(-50%, -50%);
        width: 20px; height: 20px; padding: 0; border-radius: 50%;
        border: 2px solid #fff; background: #1976d2; color: #fff;
        font: 700 9px/1 sans-serif; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 0 2px rgba(0,0,0,.55); transition: transform .08s ease-out, background .1s;
    }
    .bp-hot:hover, .bp-hot:focus-visible {
        background: #ffb300; transform: translate(-50%, -50%) scale(1.3); z-index: 3; outline: none;
    }
    .bp-hot:focus-visible { box-shadow: 0 0 0 2px #ffb300; }
    .bp-hot-sel { background: #43a047; }
    .bp-hot-dim { opacity: .15; pointer-events: none; }
    .bp-hot-code { pointer-events: none; }
</style>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<BodyPanelDto> Panels { get; set; } = Array.Empty<BodyPanelDto>();
    [Parameter] public EventCallback<BodyPanelDto> OnPanelSelected { get; set; }
    [Parameter] public IReadOnlyCollection<Guid> SelectedPanelIds { get; set; } = Array.Empty<Guid>();

    private enum ViewMode { Diagram, List }

    private string? _search;
    private BodyPanelCategory? _category;
    private ViewMode _view = ViewMode.Diagram;

    private IEnumerable<BodyPanelDto> FilteredPanels => Panels.Where(MatchesFilters);

    private IEnumerable<BodyPanelDto> DiagramPanels =>
        Panels.Where(p => p.DiagramX.HasValue && p.DiagramY.HasValue);

    private bool MatchesFilters(BodyPanelDto p)
    {
        if (_category.HasValue && p.Category != _category) return false;
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            if (!p.Code.Contains(s, StringComparison.OrdinalIgnoreCase)
                && !p.DescriptionGr.Contains(s, StringComparison.OrdinalIgnoreCase))
                return false;
        }
        return true;
    }

    private async Task OnPick(BodyPanelDto panel)
    {
        if (OnPanelSelected.HasDelegate) await OnPanelSelected.InvokeAsync(panel);
    }

    private static string Pct(decimal v) => v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private string SideLabel(PanelSide side) => side switch
    {
        PanelSide.Left => L["Left"],
        PanelSide.Right => L["Right"],
        _ => L["Center"]
    };
}
