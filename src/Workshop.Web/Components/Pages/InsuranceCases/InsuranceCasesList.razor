@page "/cases/insurance"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Workshop.Application.Common.Messaging
@using MudBlazor
@using Workshop.Application.Common.Lookups
@using Workshop.Application.Features.InsuranceCases
@using Workshop.Domain.Enums
@using Workshop.Web.Components.Shared
@inject IMediator Mediator
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<InsuranceCasesList> Log
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<PageTitle>Paint Bull — @L["InsuranceCases"]</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["InsuranceCases"]</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_search" Label="@L["Search"]" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          DebounceInterval="300" OnDebounceIntervalElapsed="Reload" Clearable />
        </MudItem>
        <MudItem xs="6" md="4">
            <MudSelect T="InsuranceCaseStatus?" @bind-Value="_statusFilter" @bind-Value:after="Reload"
                       Label="@L["Status"]" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
                @foreach (var s in Enum.GetValues<InsuranceCaseStatus>())
                {
                    <MudSelectItem T="InsuranceCaseStatus?" Value="@((InsuranceCaseStatus?)s)">@s</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudSelect T="Guid?" @bind-Value="_branchFilter" @bind-Value:after="Reload"
                       Label="@L["Branch"]" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable>
                @foreach (var b in _branches)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)b.Id)">@b.Label</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="1" Class="d-flex justify-end">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => Nav.NavigateTo("/cases/insurance/new"))">@L["New"]</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable ServerData="LoadData" T="InsuranceCaseListItemDto" Dense Hover Striped @ref="_table"
          OnRowClick="OnRowClick" RowClass="cursor-pointer">
    <HeaderContent>
        <MudTh>@L["CaseNumber"]</MudTh>
        <MudTh>@L["Status"]</MudTh>
        <MudTh>@L["Customer"]</MudTh>
        <MudTh>@L["Vehicle"]</MudTh>
        <MudTh>@L["InsuranceCompany"]</MudTh>
        <MudTh>@L["Branch"]</MudTh>
        <MudTh>@L["AssignedUser"]</MudTh>
        <MudTh>@L["AccidentDate"]</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><strong>@context.CaseNumber</strong></MudTd>
        <MudTd><CaseStatusChip Status="@context.Status" /></MudTd>
        <MudTd>@context.CustomerDisplayName</MudTd>
        <MudTd>@context.VehiclePlate — @context.VehicleBrandModel</MudTd>
        <MudTd>@context.InsuranceCompanyName</MudTd>
        <MudTd>@context.BranchName</MudTd>
        <MudTd>@context.AssignedUserName</MudTd>
        <MudTd>@(context.AccidentDate?.ToString("yyyy-MM-dd"))</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="@(new[] { 25, 50, 100 })" />
    </PagerContent>
</MudTable>

<style>.cursor-pointer td { cursor: pointer; }</style>

@code {
    private MudTable<InsuranceCaseListItemDto>? _table;
    private string? _search;
    private InsuranceCaseStatus? _statusFilter;
    private Guid? _branchFilter;
    private IReadOnlyList<LookupItem> _branches = Array.Empty<LookupItem>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _branches = await Mediator.Send(new GetBranchLookupQuery());
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to load branch lookup on InsuranceCasesList");
            Snackbar.Add(L["LoadFailed"], Severity.Error);
        }
    }

    private async Task<TableData<InsuranceCaseListItemDto>> LoadData(TableState state, CancellationToken ct)
    {
        try
        {
            var r = await Mediator.Send(new ListInsuranceCasesQuery(
                Search: _search,
                Status: _statusFilter,
                BranchId: _branchFilter,
                Page: state.Page + 1,
                PageSize: state.PageSize), ct);
            return new TableData<InsuranceCaseListItemDto> { Items = r.Items, TotalItems = r.TotalCount };
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to load insurance cases");
            Snackbar.Add(L["LoadFailed"], Severity.Error);
            return new TableData<InsuranceCaseListItemDto> { Items = Array.Empty<InsuranceCaseListItemDto>(), TotalItems = 0 };
        }
    }

    private Task Reload() => _table?.ReloadServerData() ?? Task.CompletedTask;

    private void OnRowClick(TableRowClickEventArgs<InsuranceCaseListItemDto> args) =>
        Nav.NavigateTo($"/cases/insurance/{args.Item!.Id}");
}
