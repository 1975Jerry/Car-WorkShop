@page "/cases/insurance/{Id:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Workshop.Application.Common.Messaging
@using MudBlazor
@using Workshop.Application.Features.InsuranceCases
@using Workshop.Domain.Enums
@using Workshop.Web.Components.Pages.InsuranceCases.Approval
@using Workshop.Web.Components.Pages.InsuranceCases.Assessment
@using Workshop.Web.Components.Pages.InsuranceCases.Documents
@using Workshop.Web.Components.Pages.InsuranceCases.Parts
@using Workshop.Web.Components.Pages.InsuranceCases.Repair
@using Workshop.Web.Components.Pages.InsuranceCases.Settlement
@using Workshop.Web.Components.Shared
@inject IMediator Mediator
@inject IDialogService Dialogs
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L

<PageTitle>Paint Bull — @(_case?.CaseNumber ?? "...")</PageTitle>

@if (_case is null)
{
    <MudProgressLinear Indeterminate Color="Color.Primary" />
}
else
{
    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <div>
            <MudText Typo="Typo.h4">
                @_case.CaseNumber
                <CaseStatusChip Status="@_case.Status" />
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @_case.CustomerDisplayName · @_case.VehiclePlate (@_case.VehicleBrand @_case.VehicleModel) · @_case.BranchName
            </MudText>
        </div>
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/cases/insurance"))" />
    </MudStack>

    <MudGrid>
        <MudItem xs="12" lg="8">
            <MudTabs Outlined PanelClass="pa-4" Rounded ApplyEffectsToContainer>
                <MudTabPanel Text="@L["Details"]">
                    <MudGrid>
                        <MudItem xs="12" md="6"><Field Label="@L["Customer"]" Value="@_case.CustomerDisplayName" /></MudItem>
                        <MudItem xs="12" md="6"><Field Label="@L["Phone"]" Value="@_case.CustomerPhone" /></MudItem>
                        <MudItem xs="12" md="4"><Field Label="@L["Vehicle"]" Value="@($"{_case.VehicleBrand} {_case.VehicleModel}")" /></MudItem>
                        <MudItem xs="12" md="4"><Field Label="@L["PlateNumber"]" Value="@_case.VehiclePlate" /></MudItem>
                        <MudItem xs="12" md="4"><Field Label="@L["Year"]" Value="@_case.VehicleYear?.ToString()" /></MudItem>
                        <MudItem xs="12" md="6"><Field Label="@L["InsuranceCompany"]" Value="@_case.InsuranceCompanyName" /></MudItem>
                        <MudItem xs="12" md="6"><Field Label="@L["ClaimNumber"]" Value="@_case.ClaimNumber" /></MudItem>
                        <MudItem xs="12" md="6"><Field Label="@L["AccidentDate"]" Value="@(_case.AccidentDate?.ToString("yyyy-MM-dd"))" /></MudItem>
                        <MudItem xs="12" md="6"><Field Label="@L["Mileage"]" Value="@_case.MileageAtAssessment?.ToString()" /></MudItem>

                        <MudItem xs="12"><MudDivider Class="my-2" /><MudText Typo="Typo.subtitle1">@L["Driver"]</MudText></MudItem>
                        <MudItem xs="12" md="6"><Field Label="@L["FullName"]" Value="@($"{_case.DriverLastName} {_case.DriverFirstName}".Trim())" /></MudItem>
                        <MudItem xs="12" md="6"><Field Label="@L["Phone"]" Value="@_case.DriverPhone" /></MudItem>

                        <MudItem xs="12"><MudDivider Class="my-2" /><MudText Typo="Typo.subtitle1">@L["Insurance"]</MudText></MudItem>
                        <MudItem xs="12" md="6"><Field Label="@L["Assessor"]" Value="@_case.AssessorName" /></MudItem>
                        <MudItem xs="12" md="6"><Field Label="@L["Adjuster"]" Value="@_case.AdjusterName" /></MudItem>

                        @if (!string.IsNullOrWhiteSpace(_case.Notes))
                        {
                            <MudItem xs="12">
                                <MudDivider Class="my-2" />
                                <Field Label="@L["Notes"]" Value="@_case.Notes" />
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Text="@L["Assessment"]">
                    <AssessmentEditor InsuranceCaseId="@Id" OnSaved="Refresh" />
                </MudTabPanel>
                <MudTabPanel Text="@L["Approval"]">
                    <ApprovalEditor InsuranceCaseId="@Id" OnChanged="Refresh" />
                </MudTabPanel>
                <MudTabPanel Text="@L["Parts"]">
                    <PartsTab InsuranceCaseId="@Id" OnChanged="Refresh" />
                </MudTabPanel>
                <MudTabPanel Text="@L["Repair"]">
                    <RepairTab InsuranceCaseId="@Id" OnChanged="Refresh" />
                </MudTabPanel>
                <MudTabPanel Text="@L["Settlement"]">
                    <SettlementTab InsuranceCaseId="@Id" OnChanged="Refresh" />
                </MudTabPanel>
                <MudTabPanel Text="@L["Documents"]">
                    <DocumentsTab InsuranceCaseId="@Id" OnChanged="Refresh" />
                </MudTabPanel>
                <MudTabPanel Text="@L["Timeline"]">
                    @if (_events.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["NoEvents"]</MudText>
                    }
                    else
                    {
                        <MudTimeline TimelinePosition="TimelinePosition.Start">
                            @foreach (var e in _events)
                            {
                                <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                                    <MudText Typo="Typo.body2">
                                        <strong>@e.FromStatus → @e.ToStatus</strong>
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @e.OccurredAt.ToString("yyyy-MM-dd HH:mm") · @e.TriggeredByName
                                    </MudText>
                                    @if (!string.IsNullOrWhiteSpace(e.Reason))
                                    {
                                        <MudText Typo="Typo.body2" Class="mt-1">@e.Reason</MudText>
                                    }
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                    }
                </MudTabPanel>
            </MudTabs>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Class="pa-4" Outlined Elevation="0">
                <MudText Typo="Typo.h6" Class="mb-2">@L["WorkflowActions"]</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    @L["CurrentStatus"]: <strong>@_case.Status</strong>
                </MudText>

                @if (_snapshot is not null)
                {
                    @foreach (var t in _snapshot.AvailableTriggers.Where(t => t.CanFire))
                    {
                        <MudButton Class="mb-2" FullWidth Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.ArrowForward"
                                   OnClick="@(() => Transition(t.Trigger, t.DisplayLabel))">
                            @t.DisplayLabel → @t.TargetStatus
                        </MudButton>
                    }

                    var blockers = _snapshot.AvailableTriggers.Where(t => !t.CanFire && t.BlockerReason is not null).ToList();
                    @if (blockers.Count > 0)
                    {
                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.subtitle2">@L["Blockers"]</MudText>
                        @foreach (var b in blockers)
                        {
                            <MudAlert Severity="Severity.Warning" Class="mt-2" Dense>
                                <strong>@b.DisplayLabel</strong>
                                <br />
                                <MudText Typo="Typo.caption">@b.BlockerReason</MudText>
                            </MudAlert>
                        }
                    }
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private InsuranceCaseDetailDto? _case;
    private CaseWorkflowSnapshot? _snapshot;
    private IReadOnlyList<CaseEventDto> _events = Array.Empty<CaseEventDto>();

    protected override async Task OnParametersSetAsync() => await Refresh();

    private async Task Refresh()
    {
        _case = await Mediator.Send(new GetInsuranceCaseByIdQuery(Id));
        if (_case is null) { Nav.NavigateTo("/cases/insurance"); return; }
        _snapshot = await Mediator.Send(new GetCaseWorkflowSnapshotQuery(Id));
        _events = await Mediator.Send(new GetCaseEventsQuery(Id));
    }

    private async Task Transition(CaseTriggerEvent trigger, string label)
    {
        var reason = await Dialogs.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = label,
            Message = L["ConfirmTransition"],
            YesText = L["Confirm"],
            CancelText = L["Cancel"]
        });
        if (reason != true) return;

        try
        {
            await Mediator.Send(new TransitionInsuranceCaseCommand(Id, trigger, Reason: null));
            Snackbar.Add(L["TransitionRecorded"], Severity.Success);
            await Refresh();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
